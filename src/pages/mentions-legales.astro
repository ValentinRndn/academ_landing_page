---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { Locale } from "../i18n";

const locale: Locale = "fr";
---

<Layout title="Mentions légales — Academ" description="Mentions légales du site Academ.">
	<Header locale={locale} />
	<main class="legal">
		<div class="legal__container">
			<h1 class="legal__title" data-animate>Mentions légales</h1>
			<p class="legal__updated">Dernière mise à jour : mai 2026</p>

			<section class="legal__section" data-animate data-delay="100">
				<h2>1. Éditeur du site</h2>
				<p>Le site <strong>academ.my</strong> est édité par :</p>
				<ul>
					<li><strong>Société :</strong> Imators (membre d'aktascorp)</li>
					<li><strong>Forme juridique :</strong> [À compléter]</li>
					<li><strong>SIRET :</strong> [À compléter]</li>
					<li><strong>Adresse :</strong> [À compléter]</li>
					<li><strong>Email :</strong> <a href="mailto:contact@academ.my">contact@academ.my</a></li>
				</ul>
			</section>

			<section class="legal__section" data-animate data-delay="200">
				<h2>2. Hébergeur</h2>
				<p>L'application est hébergée sur un VPS via Coolify. La base de données est opérée par MongoDB Atlas.</p>
				<ul>
					<li><strong>MongoDB, Inc.</strong> — 1633 Broadway, 38th Floor, New York, NY 10019, États-Unis</li>
				</ul>
			</section>

			<section class="legal__section" data-animate data-delay="300">
				<h2>3. Propriété intellectuelle</h2>
				<p>
					L'ensemble des contenus présents sur le site Academ (textes, images, logos, icônes, code source, etc.)
					sont protégés par les lois françaises et internationales relatives à la propriété intellectuelle.
				</p>
				<p>
					Toute reproduction, représentation, modification ou exploitation non autorisée de tout ou partie
					de ces contenus est interdite sans l'accord préalable écrit de l'éditeur.
				</p>
			</section>

			<section class="legal__section" data-animate data-delay="400">
				<h2>4. Responsabilité</h2>
				<p>
					L'éditeur s'efforce de fournir des informations aussi exactes que possible. Toutefois, il ne
					peut garantir l'exactitude, la complétude ou l'actualité des informations diffusées et décline
					toute responsabilité pour les éventuelles erreurs ou omissions.
				</p>
				<p>
					L'utilisation des informations et contenus disponibles sur le site se fait sous la pleine
					et entière responsabilité de l'utilisateur.
				</p>
			</section>

			<section class="legal__section" data-animate data-delay="500">
				<h2>5. Liens hypertextes</h2>
				<p>
					Le site peut contenir des liens vers d'autres sites internet. L'éditeur n'exerce aucun
					contrôle sur ces sites et décline toute responsabilité quant à leur contenu.
				</p>
			</section>

			<section class="legal__section" data-animate data-delay="600">
				<h2>6. Paiements</h2>
				<p>
					Les paiements effectués sur la plateforme sont traités par <a href="https://stripe.com" target="_blank" rel="noopener">Stripe</a>.
					Aucune donnée bancaire n'est stockée par Academ.
				</p>
			</section>

			<section class="legal__section" data-animate data-delay="700">
				<h2>7. Droit applicable</h2>
				<p>
					Les présentes mentions légales sont régies par le droit français. En cas de litige,
					les tribunaux français seront seuls compétents.
				</p>
			</section>

			<section class="legal__section" data-animate data-delay="800">
				<h2>8. Contact</h2>
				<p>
					Pour toute question relative aux présentes mentions légales, vous pouvez nous contacter à
					l'adresse : <a href="mailto:contact@academ.my">contact@academ.my</a>.
				</p>
			</section>
		</div>
	</main>
	<Footer locale={locale} />
</Layout>

<style>
	.legal {
		padding: 8rem 0 4rem;
		background-color: var(--surface-page);
		min-height: 100vh;
	}

	.legal__container {
		max-width: 48rem;
		margin: 0 auto;
		padding: 0 var(--spacing-section-x);
	}

	.legal__title {
		font-size: var(--text-4xl);
		font-weight: var(--font-bold);
		color: var(--color-gray-900);
		margin-bottom: 0.5rem;
	}

	.legal__updated {
		font-size: var(--text-sm);
		color: var(--color-gray-400);
		margin-bottom: 3rem;
	}

	.legal__section { margin-bottom: 2.5rem; }

	.legal__section h2 {
		font-size: var(--text-xl);
		font-weight: var(--font-semibold);
		color: var(--color-gray-900);
		margin-bottom: 0.75rem;
	}

	.legal__section p {
		font-size: var(--text-base);
		line-height: var(--leading-relaxed);
		color: var(--color-gray-600);
		margin-bottom: 0.75rem;
	}

	.legal__section ul {
		list-style: none;
		padding: 0;
		margin: 0.75rem 0;
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.legal__section li {
		font-size: var(--text-base);
		line-height: var(--leading-relaxed);
		color: var(--color-gray-600);
	}

	.legal__section a {
		color: var(--color-primary-600);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.legal__section a:hover {
		color: var(--color-primary-700);
		text-decoration: underline;
	}

	@media (max-width: 768px) {
		.legal { padding: 6rem 0 3rem; }
		.legal__title { font-size: var(--text-3xl); }
	}
</style>
