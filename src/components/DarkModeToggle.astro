---
// Vanilla-JS toggle. Initial state is set synchronously by the inline boot
// script in Layout.astro (see anti-FOUC), so this component just wires up
// the click handler and keeps the icon in sync.
---

<button
	id="dark-mode-toggle"
	type="button"
	class="dm-toggle"
	aria-label="Toggle dark mode"
	aria-pressed="false"
>
	<svg class="dm-toggle__icon dm-toggle__icon--sun" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<circle cx="12" cy="12" r="5"></circle>
		<line x1="12" y1="1" x2="12" y2="3"></line>
		<line x1="12" y1="21" x2="12" y2="23"></line>
		<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
		<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
		<line x1="1" y1="12" x2="3" y2="12"></line>
		<line x1="21" y1="12" x2="23" y2="12"></line>
		<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
		<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
	</svg>

	<svg class="dm-toggle__icon dm-toggle__icon--moon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
	</svg>
</button>

<style>
	.dm-toggle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		padding: 0;
		border: none;
		border-radius: var(--radius-full);
		background: transparent;
		color: var(--text-secondary);
		cursor: pointer;
		transition: background-color 0.2s ease, color 0.2s ease, transform 0.3s var(--ease-apple);
	}

	.dm-toggle:hover {
		background-color: var(--color-gray-100);
		color: var(--text-primary);
	}

	.dm-toggle:focus-visible {
		outline: 2px solid var(--color-primary-500);
		outline-offset: 2px;
	}

	.dm-toggle__icon {
		position: absolute;
		transition: opacity 0.3s var(--ease-apple), transform 0.4s var(--ease-apple);
	}

	/* Light mode: show moon (clicking will switch TO dark) */
	.dm-toggle__icon--sun {
		opacity: 0;
		transform: rotate(-90deg) scale(0.7);
	}
	.dm-toggle__icon--moon {
		opacity: 1;
		transform: rotate(0) scale(1);
	}

	/* Dark mode: show sun */
	html.dark .dm-toggle__icon--sun {
		opacity: 1;
		transform: rotate(0) scale(1);
		color: #fbbf24;
	}
	html.dark .dm-toggle__icon--moon {
		opacity: 0;
		transform: rotate(90deg) scale(0.7);
	}
</style>

<script is:inline>
	(function () {
		function bind() {
			const btn = document.getElementById("dark-mode-toggle");
			if (!btn || btn.dataset.bound) return;
			btn.dataset.bound = "true";

			const sync = () => {
				const isDark = document.documentElement.classList.contains("dark");
				btn.setAttribute("aria-pressed", String(isDark));
				btn.setAttribute(
					"aria-label",
					isDark ? "Switch to light mode" : "Switch to dark mode",
				);
			};

			btn.addEventListener("click", () => {
				const isDark = document.documentElement.classList.toggle("dark");
				try { localStorage.setItem("darkMode", String(isDark)); } catch (e) {}
				sync();
			});

			// Keep aria in sync if some other code flips the class.
			const observer = new MutationObserver(sync);
			observer.observe(document.documentElement, {
				attributes: true,
				attributeFilter: ["class"],
			});

			sync();
		}

		document.addEventListener("DOMContentLoaded", bind);
		document.addEventListener("astro:page-load", bind);
	})();
</script>
