---
import logoAcadem from "../assets/images/logo_academ.png";
import DarkModeToggle from "./DarkModeToggle.astro";
import { useTranslations, locales, localeNames, localizedPath, type Locale } from "../i18n";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const APP_URL = "https://app.academ.my";
const homePath = localizedPath(locale, "/");
---

<header class="header">
	<nav class="header__nav glass">
		<a href={homePath} class="header__logo" aria-label="Academ">
			<img src={logoAcadem.src} alt="Academ" class="header__logo-img" />
		</a>

		<div class="header__links">
			<a href="#features" class="link-nav">{t("landing.features")}</a>
			<a href="#how-it-works" class="link-nav">{t("landing.howItWorks")}</a>
			<a href="#testimonials" class="link-nav">{t("landing.testimonials")}</a>
			<a href="#faq" class="link-nav">{t("landing.faq")}</a>
		</div>

		<div class="header__actions">
			<DarkModeToggle />
			<details class="lang-switcher">
				<summary class="lang-switcher__trigger" aria-label="Language">
					<svg class="lang-switcher__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="10" />
						<path d="M2 12h20" />
						<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
					</svg>
					<span class="lang-switcher__current">{locale.toUpperCase()}</span>
				</summary>
				<ul class="lang-switcher__menu">
					{locales.map((code) => (
						<li>
							<a
								href={localizedPath(code, "/")}
								class:list={["lang-switcher__item", { "lang-switcher__item--active": code === locale }]}
								hreflang={code}
							>
								<span class="lang-switcher__code">{code.toUpperCase()}</span>
								<span class="lang-switcher__name">{localeNames[code]}</span>
							</a>
						</li>
					))}
				</ul>
			</details>

			<a href={`${APP_URL}/login`} class="header__login link-nav">
				{t("landing.login")}
			</a>
			<a href={`${APP_URL}/register`} class="btn-glass-primary btn-glass-primary--sm">
				{t("landing.freeTrial")}
			</a>
		</div>
	</nav>
</header>

<style>
	.header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 50;
		display: flex;
		justify-content: center;
		padding: 0.875rem 1rem;
		pointer-events: none;
	}

	.header__nav {
		pointer-events: all;
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		max-width: 72rem;
		height: 4.25rem;
		padding: 0 1rem 0 1.25rem;
		border-radius: 999px;
		gap: 1rem;
	}

	.header__logo {
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
		color: var(--color-gray-900);
	}

	.header__logo-img {
		height: 2rem;
		width: auto;
	}

	.header__logo-text {
		font-weight: var(--font-bold);
		font-size: 1.05rem;
	}

	.header__links {
		display: none;
		align-items: center;
		gap: 1.75rem;
		flex: 1;
		justify-content: center;
	}

	.header__actions {
		display: flex;
		align-items: center;
		gap: 0.625rem;
	}

	.header__login { display: none; }

	@media (min-width: 768px) {
		.header__links { display: flex; }
		.header__login { display: inline-flex; }
	}

	/* Language switcher */
	.lang-switcher {
		position: relative;
	}

	.lang-switcher__trigger {
		list-style: none;
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.5rem 0.75rem;
		border-radius: var(--radius-full);
		color: var(--color-gray-700);
		font-size: var(--text-sm);
		font-weight: var(--font-medium);
		cursor: pointer;
		transition: background-color var(--transition-fast);
	}

	.lang-switcher__trigger::-webkit-details-marker { display: none; }

	.lang-switcher__trigger:hover {
		background-color: var(--color-gray-100);
		color: var(--text-primary);
	}

	.lang-switcher__icon {
		color: var(--text-muted);
	}

	.lang-switcher__menu {
		position: absolute;
		top: calc(100% + 0.5rem);
		right: 0;
		min-width: 12rem;
		max-height: 24rem;
		overflow-y: auto;
		padding: 0.375rem;
		margin: 0;
		list-style: none;
		background: var(--surface-card-strong);
		backdrop-filter: blur(20px) saturate(160%);
		-webkit-backdrop-filter: blur(20px) saturate(160%);
		border: 1px solid var(--border-subtle);
		border-radius: var(--radius-xl);
		box-shadow: var(--shadow-lg);
		color: var(--text-primary);
	}

	.lang-switcher__item {
		display: flex;
		align-items: center;
		gap: 0.625rem;
		padding: 0.5rem 0.75rem;
		border-radius: var(--radius-md);
		color: var(--text-secondary);
		font-size: var(--text-sm);
		text-decoration: none;
		transition: background-color var(--transition-fast), color var(--transition-fast);
	}

	.lang-switcher__item:hover {
		background-color: var(--color-gray-100);
		color: var(--text-primary);
	}

	.lang-switcher__item--active {
		background-color: var(--color-primary-50);
		color: var(--color-primary-700);
		font-weight: var(--font-semibold);
	}

	.lang-switcher__code {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		font-weight: var(--font-bold);
		color: var(--text-muted);
		min-width: 2rem;
	}

	.lang-switcher__item--active .lang-switcher__code {
		color: var(--color-primary-600);
	}

	/* Dark-mode overrides live in global.css — Astro's scoping + the
	   ::before pseudo-elements made it unreliable here. */

	.lang-switcher__name { flex: 1; }
</style>
