---
import { Image } from "astro:assets";
import { useTranslations, type Locale } from "../../i18n";
import heroMockup from "../../assets/images/mockup_iphones_hero_section.png";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const APP_URL = "https://app.academ.my";
---

<section class="hero">
	<!-- Background blobs -->
	<div class="hero__bg" aria-hidden="true">
		<div class="hero__blob hero__blob--purple"></div>
		<div class="hero__blob hero__blob--pink"></div>
		<div class="hero__blob hero__blob--violet"></div>
		<div class="hero__blob hero__blob--fuchsia"></div>
	</div>

	<div class="hero__container">
		<!-- Badge -->
		<span class="hero__badge badge-glass-primary" data-animate data-delay="0">
			<svg class="hero__badge-icon" width="16" height="16" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
				<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
			</svg>
			{t("landing.bestPlatform")}
		</span>

		<!-- Title -->
		<h1 class="hero__title" data-animate data-delay="100">
			<span class="hero__title-line">{t("landing.enhanceLearning")}</span>
			<span class="hero__title-line">
				{t("landing.with")}
				<span class="hero__title-brand badge-glass-primary">Academ</span>
			</span>
		</h1>

		<!-- Subtitle -->
		<p class="hero__subtitle" data-animate data-delay="200">
			{t("landing.subtitle")}
		</p>

		<!-- CTA -->
		<div class="hero__cta" data-animate data-delay="300">
			<a href={`${APP_URL}/register`} class="btn-glass-primary btn-glass-primary--lg">
				{t("landing.getStarted")}
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<line x1="5" y1="12" x2="19" y2="12"></line>
					<polyline points="12 5 19 12 12 19"></polyline>
				</svg>
			</a>
			<a href={`${APP_URL}/login`} class="btn-glass btn-glass--lg">
				<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<polygon points="5 3 19 12 5 21 5 3"></polygon>
				</svg>
				{t("landing.watchDemo")}
			</a>
		</div>

		<!-- Hero mockup image -->
		<div class="hero__preview" data-animate data-delay="500">
			<div class="hero__mockup-glow" aria-hidden="true"></div>
			<Image
				src={heroMockup}
				alt="Academ mobile app preview"
				class="hero__mockup-image"
				widths={[480, 720, 960, 1280, 1600]}
				sizes="(max-width: 480px) 90vw, (max-width: 768px) 80vw, 48rem"
				quality={95}
				format="webp"
				loading="eager"
			/>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: 95vh;
		padding: 8rem var(--spacing-section-x) 4rem;
		overflow: hidden;
		isolation: isolate;
	}

	.hero__bg {
		position: absolute;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		overflow: hidden;
	}

	.hero__blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(110px);
		opacity: 0.5;
	}

	.hero__blob--purple {
		top: -10%;
		left: -15%;
		width: 700px;
		height: 600px;
		background: var(--color-primary-500);
	}

	.hero__blob--pink {
		top: -5%;
		right: -10%;
		width: 550px;
		height: 450px;
		background: var(--color-secondary-400);
		opacity: 0.35;
	}

	.hero__blob--violet {
		top: 30%;
		left: 25%;
		width: 450px;
		height: 350px;
		background: var(--color-primary-400);
		opacity: 0.3;
	}

	.hero__blob--fuchsia {
		top: 55%;
		right: 8%;
		width: 380px;
		height: 320px;
		background: var(--color-secondary-500);
		opacity: 0.25;
	}

	.hero__container {
		max-width: 80rem;
		margin: 0 auto;
		text-align: center;
	}

	.hero__badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-full);
		font-size: var(--text-sm);
		font-weight: var(--font-medium);
		color: var(--color-primary-700);
		margin-bottom: 2rem;
	}

	.hero__badge-icon { color: var(--color-primary-500); }

	.hero__title {
		font-size: clamp(2.5rem, 1.5rem + 4vw, 4.5rem);
		font-weight: var(--font-extrabold);
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: var(--color-gray-900);
		margin: 0 0 1.5rem;
	}

	.hero__title-line { display: block; }

	.hero__title-brand {
		display: inline-block;
		padding: 0.1em 0.55em;
		border-radius: 1rem;
		color: var(--color-primary-700);
		margin-left: 0.25em;
	}

	.hero__subtitle {
		font-size: var(--text-lg);
		line-height: var(--leading-relaxed);
		color: var(--color-gray-600);
		max-width: 36rem;
		margin: 0 auto 2.5rem;
	}

	.hero__cta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.875rem;
		justify-content: center;
		margin-bottom: 2rem;
	}

	/* Preview */
	.hero__preview {
		position: relative;
		max-width: 64rem;
		margin: 0 auto;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.hero__mockup-image {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 48rem;
		height: auto;
		display: block;
	}

	.hero__mockup-glow {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 80%;
		height: 80%;
		background: radial-gradient(circle, rgba(168, 85, 247, 0.35), rgba(236, 72, 153, 0.25) 50%, transparent 70%);
		filter: blur(60px);
		z-index: 0;
		pointer-events: none;
	}

	@media (max-width: 480px) {
		.hero { padding-top: 6rem; }
		.hero__cta { flex-direction: column; align-items: stretch; }
		.hero__mockup-image { max-width: 90vw; }
	}
</style>
