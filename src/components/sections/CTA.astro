---
import { useTranslations, type Locale } from "../../i18n";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const APP_URL = "https://app.academ.my";
---

<section class="cta">
	<div class="cta__container">
		<div class="cta__card glass" data-animate>
			<div class="cta__bg" aria-hidden="true">
				<div class="cta__blob cta__blob--1"></div>
				<div class="cta__blob cta__blob--2"></div>
			</div>

			<div class="cta__content">
				<h2 class="cta__title">{t("landing.readyToTransform")}</h2>
				<p class="cta__subtitle">{t("landing.joinThousands")}</p>
				<a href={`${APP_URL}/register`} class="btn-glass-primary btn-glass-primary--lg cta__btn">
					{t("landing.startFreeTrial")}
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<line x1="5" y1="12" x2="19" y2="12"></line>
						<polyline points="12 5 19 12 12 19"></polyline>
					</svg>
				</a>
			</div>
		</div>
	</div>
</section>

<style>
	.cta {
		padding: var(--spacing-section-y) var(--spacing-section-x);
	}

	.cta__container {
		max-width: 72rem;
		margin: 0 auto;
	}

	.cta__card {
		position: relative;
		overflow: hidden;
		border-radius: var(--radius-2xl);
		padding: clamp(3rem, 2rem + 4vw, 5rem) clamp(2rem, 1rem + 3vw, 4rem);
		text-align: center;
	}

	.cta__bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
	}

	.cta__blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
	}

	.cta__blob--1 {
		top: -30%;
		left: -10%;
		width: 400px;
		height: 350px;
		background: var(--color-primary-500);
		opacity: 0.3;
	}

	.cta__blob--2 {
		bottom: -30%;
		right: -10%;
		width: 380px;
		height: 320px;
		background: var(--color-secondary-400);
		opacity: 0.25;
	}

	.cta__content {
		position: relative;
		z-index: 1;
	}

	.cta__title {
		font-size: clamp(1.75rem, 1.25rem + 2.5vw, 3rem);
		font-weight: var(--font-bold);
		color: var(--color-gray-900);
		line-height: 1.2;
		margin: 0 0 1rem;
	}

	.cta__subtitle {
		font-size: var(--text-lg);
		color: var(--color-gray-600);
		max-width: 36rem;
		margin: 0 auto 2rem;
	}

	.cta__btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}
</style>
