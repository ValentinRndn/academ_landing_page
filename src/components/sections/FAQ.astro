---
import { useTranslations, type Locale } from "../../i18n";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const items = [1, 2, 3, 4, 5];
---

<section id="faq" class="faq">
	<div class="faq__bg" aria-hidden="true">
		<div class="faq__blob faq__blob--purple"></div>
		<div class="faq__blob faq__blob--pink"></div>
	</div>

	<div class="faq__container">
		<div class="faq__header" data-animate>
			<span class="faq__pill badge-glass-primary">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="10"></circle>
					<path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
					<line x1="12" y1="17" x2="12.01" y2="17"></line>
				</svg>
				{t("landing.faqTitle")}
			</span>
			<h2 class="faq__title">
				{t("landing.frequentlyAsked")}
				<span class="faq__title-accent">{t("landing.questions")}</span>
			</h2>
			<p class="faq__subtitle">{t("landing.faqSubtitle")}</p>
		</div>

		<div class="faq__list" data-animate data-delay="200">
			{items.map((n, i) => (
				<details class="faq__item" data-animate data-delay={i * 60}>
					<div class="faq__item-glow" aria-hidden="true"></div>
					<summary class="faq__question">
						<span class="faq__num">0{n}</span>
						<span class="faq__question-text">{t(`landing.faq${n}Question`)}</span>
						<span class="faq__icon" aria-hidden="true">
							<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
								<line x1="12" y1="5" x2="12" y2="19" class="faq__icon-bar faq__icon-bar--v"></line>
								<line x1="5" y1="12" x2="19" y2="12"></line>
							</svg>
						</span>
					</summary>
					<div class="faq__answer">
						<p>{t(`landing.faq${n}Answer`)}</p>
					</div>
				</details>
			))}
		</div>
	</div>
</section>

<style>
	.faq {
		position: relative;
		padding: var(--spacing-section-y) var(--spacing-section-x);
		overflow: hidden;
	}

	.faq__bg { position: absolute; inset: 0; pointer-events: none; z-index: -1; }

	.faq__blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(140px);
	}

	.faq__blob--purple {
		top: 10%;
		left: -8%;
		width: 560px;
		height: 460px;
		background: var(--color-primary-500);
		opacity: 0.22;
	}

	.faq__blob--pink {
		bottom: 5%;
		right: -8%;
		width: 460px;
		height: 380px;
		background: var(--color-secondary-500);
		opacity: 0.18;
	}

	.faq__container {
		position: relative;
		max-width: 56rem;
		margin: 0 auto;
	}

	/* ----- Header ----- */
	.faq__header {
		text-align: center;
		margin-bottom: 3.5rem;
	}

	.faq__pill {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-full);
		font-size: var(--text-sm);
		font-weight: var(--font-medium);
		color: var(--color-primary-700);
		margin-bottom: 1.5rem;
	}

	.faq__title {
		font-size: clamp(2rem, 1.5rem + 2.5vw, 3.25rem);
		font-weight: var(--font-bold);
		color: var(--color-gray-900);
		margin: 0 0 1rem;
		line-height: 1.15;
		letter-spacing: -0.02em;
	}

	.faq__title-accent {
		background: linear-gradient(135deg, var(--color-primary-400), var(--color-secondary-500));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		margin-left: 0.4rem;
	}

	.faq__subtitle {
		font-size: var(--text-lg);
		color: var(--color-gray-500);
		max-width: 36rem;
		margin: 0 auto;
	}

	/* ============== LIST ============== */
	.faq__list {
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
	}

	/* ============== ITEM ============== */
	.faq__item {
		position: relative;
		border-radius: var(--radius-xl);
		background:
			radial-gradient(120% 100% at 20% 0%, rgba(168, 85, 247, 0.1), transparent 60%),
			linear-gradient(180deg, rgba(168, 85, 247, 0.04), rgba(236, 72, 153, 0.02));
		border: 1px solid rgba(168, 85, 247, 0.18);
		backdrop-filter: blur(14px) saturate(160%);
		-webkit-backdrop-filter: blur(14px) saturate(160%);
		overflow: hidden;
		isolation: isolate;
		transition:
			border-color var(--transition-base),
			background var(--transition-base);
	}

	.faq__item:hover {
		border-color: rgba(168, 85, 247, 0.35);
	}

	.faq__item[open] {
		border-color: rgba(168, 85, 247, 0.5);
		background:
			radial-gradient(120% 100% at 20% 0%, rgba(168, 85, 247, 0.15), transparent 60%),
			linear-gradient(180deg, rgba(168, 85, 247, 0.06), rgba(236, 72, 153, 0.04));
	}

	.faq__item-glow {
		position: absolute;
		top: -50%;
		right: -10%;
		width: 50%;
		height: 200%;
		background: radial-gradient(circle, rgba(236, 72, 153, 0.25), transparent 65%);
		filter: blur(50px);
		opacity: 0;
		transition: opacity var(--transition-base);
		pointer-events: none;
		z-index: -1;
	}

	.faq__item[open] .faq__item-glow {
		opacity: 1;
	}

	/* ----- Question (summary) ----- */
	.faq__question {
		list-style: none;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
		padding: 1.25rem 1.5rem;
		cursor: pointer;
		font-weight: var(--font-semibold);
		font-size: 1rem;
		color: var(--color-gray-900);
	}

	.faq__question::-webkit-details-marker { display: none; }
	.faq__question::marker { display: none; }

	.faq__num {
		font-size: 0.85rem;
		font-weight: var(--font-bold);
		letter-spacing: 0.05em;
		min-width: 1.75rem;
		background: linear-gradient(135deg, var(--color-primary-400), var(--color-secondary-500));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		opacity: 0.7;
		transition: opacity var(--transition-base);
	}

	.faq__item:hover .faq__num,
	.faq__item[open] .faq__num {
		opacity: 1;
	}

	.faq__question-text {
		font-size: 1rem;
		font-weight: var(--font-semibold);
		color: var(--color-gray-900);
		letter-spacing: -0.005em;
	}

	/* ----- Animated +/- icon ----- */
	.faq__icon {
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		background: rgba(168, 85, 247, 0.1);
		border: 1px solid rgba(168, 85, 247, 0.3);
		color: var(--color-primary-400);
		transition:
			background var(--transition-base),
			border-color var(--transition-base),
			transform var(--transition-base);
	}

	.faq__item[open] .faq__icon {
		background: linear-gradient(135deg, var(--color-primary-400), var(--color-secondary-500));
		border-color: transparent;
		color: white;
		transform: rotate(45deg);
	}

	/* ----- Answer ----- */
	.faq__answer {
		padding: 0 1.5rem 1.25rem 4.5rem;
		overflow: hidden;
	}

	.faq__answer p {
		margin: 0;
		font-size: 0.9rem;
		line-height: var(--leading-relaxed);
		color: var(--color-gray-600);
	}

	/* Smooth expand animation */
	.faq__item[open] .faq__answer {
		animation: faq-expand 0.35s ease;
	}

	@keyframes faq-expand {
		from {
			opacity: 0;
			transform: translateY(-6px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 480px) {
		.faq__question {
			grid-template-columns: 1fr auto;
			padding: 1rem 1.25rem;
			gap: 0.75rem;
		}
		.faq__num { display: none; }
		.faq__icon {
			width: 2rem;
			height: 2rem;
			margin-left: auto;
		}
		.faq__answer { padding: 0 1.25rem 1rem 1.25rem; }
	}
</style>
