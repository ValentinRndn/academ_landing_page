---
import { useTranslations, type Locale } from "../../i18n";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const features = [
	{
		key: "verifiedTutors",
		icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
	},
	{
		key: "flexibleScheduling",
		icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />`,
	},
	{
		key: "progressTracking",
		icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />`,
	},
	{
		key: "securePayments",
		icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />`,
	},
];
---

<section id="features" class="features">
	<div class="features__bg" aria-hidden="true">
		<div class="features__blob features__blob--purple"></div>
		<div class="features__blob features__blob--violet"></div>
	</div>

	<div class="features__container">
		<div class="features__header" data-animate>
			<span class="features__pill badge-glass-primary">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
				</svg>
				{t("landing.keyFeatures")}
			</span>
			<h2 class="features__title">
				{t("landing.boostYourLearning")}<br />
				<span class="features__title-accent">Academ</span>
			</h2>
		</div>

		<div class="features__grid">
			{features.map((f, i) => (
				<div class="features__item" data-animate data-delay={i * 100}>
					<div class="features__icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" set:html={f.icon} />
					</div>
					<h3 class="features__item-title">{t(`landing.${f.key}`)}</h3>
					<p class="features__item-desc">{t(`landing.${f.key}Desc`)}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.features {
		position: relative;
		padding: var(--spacing-section-y) var(--spacing-section-x);
		overflow: hidden;
	}

	.features__bg { position: absolute; inset: 0; pointer-events: none; z-index: -1; }

	.features__blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(120px);
	}

	.features__blob--purple {
		top: 10%;
		left: -10%;
		width: 500px;
		height: 400px;
		background: var(--color-primary-500);
		opacity: 0.18;
	}

	.features__blob--violet {
		bottom: 5%;
		right: 15%;
		width: 400px;
		height: 320px;
		background: var(--color-primary-400);
		opacity: 0.15;
	}

	.features__container {
		max-width: 80rem;
		margin: 0 auto;
	}

	.features__header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.features__pill {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-full);
		font-size: var(--text-sm);
		font-weight: var(--font-medium);
		color: var(--color-primary-700);
		margin-bottom: 1.5rem;
	}

	.features__title {
		font-size: clamp(2rem, 1.5rem + 2.5vw, 3.25rem);
		font-weight: var(--font-bold);
		color: var(--color-gray-900);
		margin: 0;
		line-height: 1.15;
	}

	.features__title-accent { color: var(--color-primary-600); }

	.features__grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}

	@media (min-width: 640px) {
		.features__grid { grid-template-columns: repeat(2, 1fr); }
	}

	@media (min-width: 1024px) {
		.features__grid { grid-template-columns: repeat(4, 1fr); gap: 2.5rem; }
	}

	.features__item {
		text-align: left;
	}

	.features__icon {
		width: 3rem;
		height: 3rem;
		border-radius: var(--radius-xl);
		background: var(--color-primary-100);
		color: var(--color-primary-600);
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 1rem;
		transition: transform var(--transition-base);
	}

	.features__item:hover .features__icon {
		transform: scale(1.1);
	}

	.features__item-title {
		font-size: 1.05rem;
		font-weight: var(--font-bold);
		color: var(--color-gray-900);
		margin: 0 0 0.5rem;
	}

	.features__item-desc {
		font-size: var(--text-sm);
		line-height: var(--leading-relaxed);
		color: var(--color-gray-500);
		margin: 0;
	}
</style>
