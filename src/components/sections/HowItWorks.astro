---
import { useTranslations, type Locale } from "../../i18n";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="how-it-works" class="how">
	<div class="how__bg" aria-hidden="true">
		<div class="how__blob how__blob--purple"></div>
		<div class="how__blob how__blob--pink"></div>
	</div>

	<div class="how__container">
		<div class="how__header" data-animate>
			<span class="how__pill badge-glass-primary">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
				</svg>
				{t("landing.howItWorksTitle")}
			</span>
			<h2 class="how__title">
				{t("landing.learningMadeSimple")}<br />
				<span class="how__title-accent">{t("landing.resultsMadeReal")}</span>
			</h2>
			<p class="how__subtitle">{t("landing.howItWorksSubtitle")}</p>
		</div>

		<div class="how__steps">
			<!-- Vertical connector line -->
			<div class="how__connector" aria-hidden="true">
				<div class="how__connector-line"></div>
			</div>

			<!-- Step 1 -->
			<article class="how__step how__step--purple" data-animate data-delay="0">
				<div class="how__step-marker" aria-hidden="true">
					<span class="how__step-number">01</span>
					<span class="how__step-pulse"></span>
				</div>

				<div class="how__step-content">
					<div class="how__step-text">
						<span class="how__step-tag">{t("landing.howItWorksTitle")}</span>
						<h3 class="how__step-title">{t("landing.signUpCustomize")}</h3>
						<p class="how__step-desc">{t("landing.signUpCustomizeDesc")}</p>
					</div>

					<div class="how__step-visual">
						<div class="how__visual-glow how__visual-glow--purple" aria-hidden="true"></div>
						<div class="how__stats-card glass">
							<div class="how__stats-row">
								<div class="how__stats-icon">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
										<circle cx="9" cy="7" r="4"></circle>
										<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
										<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
									</svg>
								</div>
								<span class="how__stats-label">{t("landing.totalUsers")}</span>
							</div>
							<div class="how__stats-figure">
								<span class="how__stats-number">20K+</span>
								<span class="how__stats-tag">Users</span>
							</div>
							<div class="how__stats-rows">
								<div class="how__stats-line">
									<span>{t("landing.monthlyUsers")}</span>
									<strong>1K+</strong>
								</div>
								<div class="how__stats-line">
									<span>{t("landing.yearlyUsers")}</span>
									<strong>10K+</strong>
								</div>
							</div>
							<div class="how__stats-avatars">
								<div class="how__avatar how__avatar--1"></div>
								<div class="how__avatar how__avatar--2"></div>
								<div class="how__avatar how__avatar--3"></div>
								<div class="how__avatar how__avatar--more">+5</div>
								<span class="how__stats-active">
									<span class="how__stats-dot"></span>
									{t("landing.activeNow")}
								</span>
							</div>
						</div>
					</div>
				</div>
			</article>

			<!-- Step 2 (reversed) -->
			<article class="how__step how__step--pink how__step--reverse" data-animate data-delay="150">
				<div class="how__step-marker" aria-hidden="true">
					<span class="how__step-number">02</span>
					<span class="how__step-pulse"></span>
				</div>

				<div class="how__step-content">
					<div class="how__step-text">
						<span class="how__step-tag">{t("landing.howItWorksTitle")}</span>
						<h3 class="how__step-title">{t("landing.connectWithExperts")}</h3>
						<p class="how__step-desc">{t("landing.connectWithExpertsDesc")}</p>
					</div>

					<div class="how__step-visual">
						<div class="how__visual-glow how__visual-glow--pink" aria-hidden="true"></div>
						<div class="how__connect-card glass">
							<div class="how__connect">
								<div class="how__connect-side">
									<div class="how__connect-bubble how__connect-bubble--primary">T</div>
									<span>{t("landing.teacher")}</span>
								</div>
								<div class="how__connect-link" aria-hidden="true">
									<div class="how__connect-line"></div>
									<div class="how__connect-icon">
										<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
										</svg>
									</div>
									<div class="how__connect-line"></div>
								</div>
								<div class="how__connect-side">
									<div class="how__connect-bubble">S</div>
									<span>{t("landing.student")}</span>
								</div>
							</div>
							<div class="how__connect-meta">
								<span>{t("landing.integrationsWithPlatforms")}</span>
								<strong>20+</strong>
							</div>
						</div>
					</div>
				</div>
			</article>
		</div>
	</div>
</section>

<style>
	.how {
		position: relative;
		padding: var(--spacing-section-y) var(--spacing-section-x);
		overflow: hidden;
	}

	.how__bg { position: absolute; inset: 0; pointer-events: none; z-index: -1; }

	.how__blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(140px);
	}

	.how__blob--purple {
		top: -10%;
		right: -10%;
		width: 600px;
		height: 500px;
		background: var(--color-primary-500);
		opacity: 0.22;
	}

	.how__blob--pink {
		bottom: -5%;
		left: -8%;
		width: 480px;
		height: 380px;
		background: var(--color-secondary-500);
		opacity: 0.18;
	}

	.how__container {
		position: relative;
		max-width: 80rem;
		margin: 0 auto;
	}

	/* ----- Header ----- */
	.how__header {
		text-align: center;
		margin-bottom: 4.5rem;
	}

	.how__pill {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-full);
		font-size: var(--text-sm);
		font-weight: var(--font-medium);
		color: var(--color-primary-700);
		margin-bottom: 1.5rem;
	}

	.how__title {
		font-size: clamp(2rem, 1.5rem + 2.5vw, 3.25rem);
		font-weight: var(--font-bold);
		color: var(--color-gray-900);
		margin: 0 0 1rem;
		line-height: 1.15;
		letter-spacing: -0.02em;
	}

	.how__title-accent {
		background: linear-gradient(135deg, var(--color-primary-400), var(--color-secondary-500));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.how__subtitle {
		font-size: var(--text-lg);
		color: var(--color-gray-500);
		max-width: 36rem;
		margin: 0 auto;
	}

	/* ============== STEPS ============== */
	.how__steps {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	/* Vertical connector running through the markers */
	.how__connector {
		position: absolute;
		top: 3rem;
		bottom: 3rem;
		left: 1.5rem;
		width: 2px;
		pointer-events: none;
	}

	.how__connector-line {
		width: 100%;
		height: 100%;
		background: linear-gradient(
			to bottom,
			transparent 0%,
			rgba(168, 85, 247, 0.5) 15%,
			rgba(236, 72, 153, 0.5) 85%,
			transparent 100%
		);
	}

	@media (min-width: 768px) {
		.how__connector { left: 50%; transform: translateX(-50%); }
	}

	/* ----- Single step ----- */
	.how__step {
		position: relative;
		display: grid;
		grid-template-columns: 3rem 1fr;
		gap: 1rem;
		align-items: stretch;
	}

	@media (min-width: 768px) {
		.how__step { grid-template-columns: 1fr; gap: 0; }
	}

	.how__step-marker {
		position: relative;
		width: 3rem;
		height: 3rem;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		background: rgba(168, 85, 247, 0.12);
		border: 1.5px solid rgba(168, 85, 247, 0.45);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		z-index: 2;
	}

	.how__step--pink .how__step-marker {
		background: rgba(236, 72, 153, 0.12);
		border-color: rgba(236, 72, 153, 0.45);
	}

	@media (min-width: 768px) {
		.how__step-marker {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
		}
	}

	.how__step-number {
		font-size: 0.95rem;
		font-weight: var(--font-bold);
		background: linear-gradient(135deg, var(--color-primary-400), var(--color-secondary-500));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		letter-spacing: -0.02em;
	}

	.how__step-pulse {
		position: absolute;
		inset: -4px;
		border-radius: 50%;
		border: 1.5px solid rgba(168, 85, 247, 0.5);
		opacity: 0;
		animation: pulse-ring 2.5s ease-out infinite;
	}

	.how__step--pink .how__step-pulse {
		border-color: rgba(236, 72, 153, 0.5);
	}

	@keyframes pulse-ring {
		0% { opacity: 0.7; transform: scale(0.85); }
		100% { opacity: 0; transform: scale(1.4); }
	}

	/* Content row : text + visual side by side */
	.how__step-content {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		padding: 2rem;
		border-radius: var(--radius-2xl);
		background:
			radial-gradient(120% 80% at 20% 0%, rgba(168, 85, 247, 0.12), transparent 60%),
			linear-gradient(180deg, rgba(168, 85, 247, 0.05), rgba(236, 72, 153, 0.03));
		border: 1px solid rgba(168, 85, 247, 0.2);
		backdrop-filter: blur(18px) saturate(160%);
		-webkit-backdrop-filter: blur(18px) saturate(160%);
		isolation: isolate;
		overflow: hidden;
		position: relative;
	}

	.how__step--pink .how__step-content {
		background:
			radial-gradient(120% 80% at 80% 0%, rgba(236, 72, 153, 0.12), transparent 60%),
			linear-gradient(180deg, rgba(236, 72, 153, 0.05), rgba(168, 85, 247, 0.03));
		border-color: rgba(236, 72, 153, 0.2);
	}

	.how__step-content::before {
		content: "";
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(168, 85, 247, 0.06) 1px, transparent 1px),
			linear-gradient(90deg, rgba(168, 85, 247, 0.06) 1px, transparent 1px);
		background-size: 40px 40px;
		mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 30%, transparent 75%);
		-webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 30%, transparent 75%);
		opacity: 0.4;
		pointer-events: none;
		z-index: 0;
	}

	@media (min-width: 768px) {
		.how__step-content {
			grid-template-columns: 1fr 1fr;
			gap: 3rem;
			padding: 2.5rem 3rem;
			align-items: center;
			width: calc(50% - 2rem);
			margin-right: auto;
		}

		.how__step--reverse .how__step-content {
			margin-left: auto;
			margin-right: 0;
			grid-template-areas: "visual text";
		}

		.how__step--reverse .how__step-text { grid-area: text; }
		.how__step--reverse .how__step-visual { grid-area: visual; }
	}

	.how__step-text { position: relative; z-index: 1; }

	.how__step-tag {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: var(--font-bold);
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--color-primary-400);
		margin-bottom: 0.75rem;
	}

	.how__step--pink .how__step-tag { color: var(--color-secondary-400); }

	.how__step-title {
		font-size: clamp(1.35rem, 1.1rem + 0.8vw, 1.75rem);
		font-weight: var(--font-bold);
		color: var(--color-gray-900);
		margin: 0 0 0.75rem;
		letter-spacing: -0.01em;
	}

	.how__step-desc {
		font-size: var(--text-base);
		line-height: var(--leading-relaxed);
		color: var(--color-gray-400);
		margin: 0;
	}

	.how__step-visual {
		position: relative;
		display: flex;
		justify-content: center;
		align-items: center;
		z-index: 1;
	}

	.how__visual-glow {
		position: absolute;
		inset: -10%;
		border-radius: 50%;
		filter: blur(40px);
		z-index: 0;
		pointer-events: none;
	}

	.how__visual-glow--purple {
		background: radial-gradient(circle, rgba(168, 85, 247, 0.4), transparent 65%);
	}

	.how__visual-glow--pink {
		background: radial-gradient(circle, rgba(236, 72, 153, 0.4), transparent 65%);
	}

	/* ----- Stats card ----- */
	.how__stats-card {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 22rem;
		padding: 1.25rem;
		border-radius: var(--radius-xl);
	}

	.how__stats-row {
		display: flex;
		align-items: center;
		gap: 0.625rem;
		margin-bottom: 0.75rem;
	}

	.how__stats-icon {
		width: 2.25rem;
		height: 2.25rem;
		border-radius: var(--radius-md);
		background: var(--color-primary-100);
		color: var(--color-primary-600);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.how__stats-label {
		font-size: var(--text-sm);
		font-weight: var(--font-semibold);
		color: var(--color-gray-900);
	}

	.how__stats-figure {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		margin-bottom: 0.75rem;
	}

	.how__stats-number {
		font-size: 1.875rem;
		font-weight: var(--font-bold);
		color: var(--color-gray-900);
	}

	.how__stats-tag {
		font-size: 0.75rem;
		font-weight: var(--font-medium);
		color: var(--color-primary-600);
		background: var(--color-primary-50);
		padding: 0.125rem 0.5rem;
		border-radius: var(--radius-full);
	}

	.how__stats-rows {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
		margin-bottom: 1rem;
	}

	.how__stats-line {
		display: flex;
		justify-content: space-between;
		font-size: 0.75rem;
		color: var(--color-gray-500);
	}

	.how__stats-line strong {
		color: var(--color-gray-900);
		background: rgba(255, 255, 255, 0.6);
		padding: 0.125rem 0.5rem;
		border-radius: var(--radius-md);
		font-weight: var(--font-semibold);
	}

	.how__stats-avatars {
		display: flex;
		align-items: center;
		gap: 0.625rem;
		padding-top: 0.75rem;
		border-top: 1px solid rgba(255, 255, 255, 0.5);
	}

	.how__avatar {
		width: 2rem;
		height: 2rem;
		border-radius: var(--radius-full);
		border: 2px solid rgba(255, 255, 255, 0.85);
		margin-left: -0.375rem;
		box-shadow: var(--shadow-sm);
	}

	.how__avatar:first-child { margin-left: 0; }
	.how__avatar--1 { background: linear-gradient(135deg, var(--color-primary-400), var(--color-primary-600)); }
	.how__avatar--2 { background: linear-gradient(135deg, var(--color-primary-300), var(--color-primary-500)); }
	.how__avatar--3 { background: linear-gradient(135deg, #c084fc, #7e22ce); }

	.how__avatar--more {
		background: rgba(255, 255, 255, 0.85);
		color: var(--color-gray-700);
		font-size: 0.65rem;
		font-weight: var(--font-bold);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.how__stats-active {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.75rem;
		color: var(--color-gray-500);
		margin-left: 0.25rem;
	}

	.how__stats-dot {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		background: #4ade80;
		box-shadow: 0 0 8px rgba(74, 222, 128, 0.7);
		animation: pulse-dot 2s ease-in-out infinite;
	}

	@keyframes pulse-dot {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.4; }
	}

	/* ----- Connect card ----- */
	.how__connect-card {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 22rem;
		padding: 1.5rem;
		border-radius: var(--radius-xl);
	}

	.how__connect {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
	}

	.how__connect-side { text-align: center; }

	.how__connect-side span {
		display: block;
		margin-top: 0.5rem;
		font-size: 0.75rem;
		font-weight: var(--font-medium);
		color: var(--color-gray-600);
	}

	.how__connect-bubble {
		width: 3.5rem;
		height: 3.5rem;
		border-radius: var(--radius-xl);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.25rem;
		font-weight: var(--font-bold);
		background: rgba(255, 255, 255, 0.65);
		backdrop-filter: blur(16px);
		color: var(--color-gray-700);
	}

	.how__connect-bubble--primary {
		background: rgba(168, 85, 247, 0.15);
		border: 1px solid rgba(168, 85, 247, 0.4);
		color: var(--color-primary-700);
	}

	.how__connect-link {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.how__connect-line {
		width: 1.5rem;
		height: 2px;
		background: linear-gradient(to right, var(--color-primary-300), var(--color-secondary-400));
	}

	.how__connect-icon {
		width: 2.75rem;
		height: 2.75rem;
		border-radius: var(--radius-lg);
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(236, 72, 153, 0.15);
		border: 1px solid rgba(236, 72, 153, 0.4);
		color: var(--color-secondary-500);
	}

	.how__connect-meta {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-top: 1.25rem;
		padding-top: 1rem;
		border-top: 1px solid rgba(255, 255, 255, 0.5);
		font-size: var(--text-sm);
		color: var(--color-gray-500);
	}

	.how__connect-meta strong {
		color: var(--color-secondary-500);
		font-weight: var(--font-bold);
	}

	@media (max-width: 480px) {
		.how__step-content { padding: 1.5rem; }
	}
</style>
