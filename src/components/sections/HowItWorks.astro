---
import { useTranslations, type Locale } from "../../i18n";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="how-it-works" class="how">
	<div class="how__bg" aria-hidden="true">
		<div class="how__blob how__blob--purple"></div>
		<div class="how__blob how__blob--pink"></div>
	</div>

	<div class="how__container">
		<div class="how__header" data-animate>
			<span class="how__pill badge-glass-primary">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
				</svg>
				{t("landing.howItWorksTitle")}
			</span>
			<h2 class="how__title">
				{t("landing.learningMadeSimple")}<br />
				<span class="how__title-accent">{t("landing.resultsMadeReal")}</span>
			</h2>
			<p class="how__subtitle">{t("landing.howItWorksSubtitle")}</p>
		</div>

		<div class="how__steps">
			<!-- Vertical connector line -->
			<div class="how__connector" aria-hidden="true">
				<div class="how__connector-line"></div>
			</div>

			<!-- Step 1 -->
			<article class="how__step how__step--purple" data-animate data-delay="0">
				<div class="how__step-marker" aria-hidden="true">
					<span class="how__step-number">01</span>
				</div>

				<div class="how__step-content">
					<div class="how__step-text">
						<span class="how__step-tag">{t("landing.howItWorksTitle")}</span>
						<h3 class="how__step-title">{t("landing.signUpCustomize")}</h3>
						<p class="how__step-desc">{t("landing.signUpCustomizeDesc")}</p>
					</div>

					<div class="how__step-visual">
						<div class="how__visual-glow how__visual-glow--purple" aria-hidden="true"></div>
						<div class="how__profile-card glass">
							<div class="how__profile-head">
								<div class="how__profile-icon">
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
										<circle cx="12" cy="7" r="4"></circle>
									</svg>
								</div>
								<span class="how__profile-title">Customize your profile</span>
							</div>

							<div class="how__profile-block">
								<span class="how__profile-label">Subjects</span>
								<div class="how__profile-chips">
									<span class="how__chip how__chip--active">
										<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
										Mathematics
									</span>
									<span class="how__chip how__chip--active">
										<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
										Physics
									</span>
									<span class="how__chip">Chemistry</span>
									<span class="how__chip">English</span>
								</div>
							</div>

							<div class="how__profile-block">
								<span class="how__profile-label">Level</span>
								<div class="how__profile-radios">
									<span class="how__radio">
										<span class="how__radio-dot"></span>
										Beginner
									</span>
									<span class="how__radio how__radio--active">
										<span class="how__radio-dot"></span>
										Intermediate
									</span>
									<span class="how__radio">
										<span class="how__radio-dot"></span>
										Advanced
									</span>
								</div>
							</div>

							<div class="how__profile-cta">
								Continue
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
									<line x1="5" y1="12" x2="19" y2="12"></line>
									<polyline points="12 5 19 12 12 19"></polyline>
								</svg>
							</div>
						</div>
					</div>
				</div>
			</article>

			<!-- Step 2 (reversed) -->
			<article class="how__step how__step--pink how__step--reverse" data-animate data-delay="150">
				<div class="how__step-marker" aria-hidden="true">
					<span class="how__step-number">02</span>
				</div>

				<div class="how__step-content">
					<div class="how__step-text">
						<span class="how__step-tag">{t("landing.howItWorksTitle")}</span>
						<h3 class="how__step-title">{t("landing.connectWithExperts")}</h3>
						<p class="how__step-desc">{t("landing.connectWithExpertsDesc")}</p>
					</div>

					<div class="how__step-visual">
						<div class="how__visual-glow how__visual-glow--pink" aria-hidden="true"></div>
						<div class="how__connect-card glass">
							<div class="how__connect">
								<div class="how__connect-side">
									<div class="how__connect-photo how__connect-photo--teacher">
										<img src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=200&h=200&fit=crop&crop=faces&auto=format&q=80" alt="" loading="lazy" />
									</div>
									<span>{t("landing.teacher")}</span>
								</div>
								<div class="how__connect-link" aria-hidden="true">
									<div class="how__connect-line"></div>
									<div class="how__connect-icon">
										<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
										</svg>
									</div>
									<div class="how__connect-line"></div>
								</div>
								<div class="how__connect-side">
									<div class="how__connect-photo how__connect-photo--student">
										<img src="https://images.unsplash.com/photo-1539571696357-5a69c17a67c6?w=200&h=200&fit=crop&crop=faces&auto=format&q=80" alt="" loading="lazy" />
									</div>
									<span>{t("landing.student")}</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</article>
		</div>
	</div>
</section>

<style>
	.how {
		position: relative;
		padding: var(--spacing-section-y) var(--spacing-section-x);
		overflow: hidden;
	}

	.how__bg { position: absolute; inset: 0; pointer-events: none; z-index: -1; }

	.how__blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(140px);
	}

	.how__blob--purple {
		top: -10%;
		right: -10%;
		width: 600px;
		height: 500px;
		background: var(--color-primary-500);
		opacity: 0.22;
	}

	.how__blob--pink {
		bottom: -5%;
		left: -8%;
		width: 480px;
		height: 380px;
		background: var(--color-secondary-500);
		opacity: 0.18;
	}

	.how__container {
		position: relative;
		max-width: 80rem;
		margin: 0 auto;
	}

	/* ----- Header ----- */
	.how__header {
		text-align: center;
		margin-bottom: 4.5rem;
	}

	.how__pill {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: var(--radius-full);
		font-size: var(--text-sm);
		font-weight: var(--font-medium);
		color: var(--color-primary-700);
		margin-bottom: 1.5rem;
	}

	.how__title {
		font-size: clamp(2rem, 1.5rem + 2.5vw, 3.25rem);
		font-weight: var(--font-bold);
		color: var(--color-gray-900);
		margin: 0 0 1rem;
		line-height: 1.15;
		letter-spacing: -0.02em;
	}

	.how__title-accent {
		background: linear-gradient(135deg, var(--color-primary-400), var(--color-secondary-500));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.how__subtitle {
		font-size: var(--text-lg);
		color: var(--color-gray-500);
		max-width: 36rem;
		margin: 0 auto;
	}

	/* ============== STEPS ============== */
	.how__steps {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	/* Vertical connector running down the left side */
	.how__connector {
		position: absolute;
		top: 3rem;
		bottom: 3rem;
		left: 1.5rem;
		width: 2px;
		pointer-events: none;
	}

	.how__connector-line {
		width: 100%;
		height: 100%;
		background: linear-gradient(
			to bottom,
			transparent 0%,
			rgba(168, 85, 247, 0.5) 15%,
			rgba(236, 72, 153, 0.5) 85%,
			transparent 100%
		);
	}

	/* ----- Single step ----- */
	.how__step {
		position: relative;
		display: grid;
		grid-template-columns: 3rem 1fr;
		gap: 1rem;
		align-items: stretch;
	}

	.how__step-marker {
		position: relative;
		width: 3rem;
		height: 3rem;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		background: rgba(168, 85, 247, 0.12);
		border: 1.5px solid rgba(168, 85, 247, 0.45);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		z-index: 2;
		margin-top: 1.5rem;
	}

	.how__step--pink .how__step-marker {
		background: rgba(236, 72, 153, 0.12);
		border-color: rgba(236, 72, 153, 0.45);
	}

	.how__step-number {
		font-size: 0.95rem;
		font-weight: var(--font-bold);
		background: linear-gradient(135deg, var(--color-primary-400), var(--color-secondary-500));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		letter-spacing: -0.02em;
	}

	/* Content row : text + visual side by side */
	.how__step-content {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		padding: 2rem;
		border-radius: var(--radius-2xl);
		background:
			radial-gradient(120% 80% at 20% 0%, rgba(168, 85, 247, 0.12), transparent 60%),
			linear-gradient(180deg, rgba(168, 85, 247, 0.05), rgba(236, 72, 153, 0.03));
		border: 1px solid rgba(168, 85, 247, 0.2);
		backdrop-filter: blur(18px) saturate(160%);
		-webkit-backdrop-filter: blur(18px) saturate(160%);
		isolation: isolate;
		overflow: hidden;
		position: relative;
		min-width: 0;
	}

	.how__step--pink .how__step-content {
		background:
			radial-gradient(120% 80% at 80% 0%, rgba(236, 72, 153, 0.12), transparent 60%),
			linear-gradient(180deg, rgba(236, 72, 153, 0.05), rgba(168, 85, 247, 0.03));
		border-color: rgba(236, 72, 153, 0.2);
	}

	.how__step-content::before {
		content: "";
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(168, 85, 247, 0.06) 1px, transparent 1px),
			linear-gradient(90deg, rgba(168, 85, 247, 0.06) 1px, transparent 1px);
		background-size: 40px 40px;
		mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 30%, transparent 75%);
		-webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 30%, transparent 75%);
		opacity: 0.4;
		pointer-events: none;
		z-index: 0;
	}

	@media (min-width: 768px) {
		.how__step-content {
			grid-template-columns: 1fr 1fr;
			gap: 3rem;
			padding: 2.5rem 3rem;
			align-items: center;
		}

		.how__step--reverse .how__step-content {
			grid-template-areas: "visual text";
		}

		.how__step--reverse .how__step-text { grid-area: text; }
		.how__step--reverse .how__step-visual { grid-area: visual; }
	}

	.how__step-text { position: relative; z-index: 1; min-width: 0; }

	.how__step-tag {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: var(--font-bold);
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--color-primary-400);
		margin-bottom: 0.75rem;
	}

	.how__step--pink .how__step-tag { color: var(--color-secondary-400); }

	.how__step-title {
		font-size: clamp(1.35rem, 1.1rem + 0.8vw, 1.75rem);
		font-weight: var(--font-bold);
		color: var(--color-gray-900);
		margin: 0 0 0.75rem;
		letter-spacing: -0.01em;
	}

	.how__step-desc {
		font-size: var(--text-base);
		line-height: var(--leading-relaxed);
		color: var(--color-gray-400);
		margin: 0;
	}

	.how__step-visual {
		position: relative;
		display: flex;
		justify-content: center;
		align-items: center;
		z-index: 1;
		min-width: 0;
	}

	.how__visual-glow {
		position: absolute;
		inset: -10%;
		border-radius: 50%;
		filter: blur(40px);
		z-index: 0;
		pointer-events: none;
	}

	.how__visual-glow--purple {
		background: radial-gradient(circle, rgba(168, 85, 247, 0.4), transparent 65%);
	}

	.how__visual-glow--pink {
		background: radial-gradient(circle, rgba(236, 72, 153, 0.4), transparent 65%);
	}

	/* ----- Profile customization card ----- */
	.how__profile-card {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 22rem;
		padding: 1.25rem;
		border-radius: var(--radius-xl);
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.how__profile-head {
		display: flex;
		align-items: center;
		gap: 0.625rem;
	}

	.how__profile-icon {
		width: 2rem;
		height: 2rem;
		border-radius: var(--radius-md);
		background: rgba(168, 85, 247, 0.15);
		border: 1px solid rgba(168, 85, 247, 0.3);
		color: var(--color-primary-500);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.how__profile-title {
		font-size: 0.875rem;
		font-weight: var(--font-bold);
		color: var(--color-gray-900);
		letter-spacing: -0.01em;
	}

	.how__profile-block {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.how__profile-label {
		font-size: 0.7rem;
		font-weight: var(--font-bold);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-gray-500);
	}

	.how__profile-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.how__chip {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		padding: 0.35rem 0.625rem;
		border-radius: var(--radius-full);
		font-size: 0.72rem;
		font-weight: var(--font-medium);
		color: var(--color-gray-500);
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(168, 85, 247, 0.18);
		transition: all 0.2s ease;
	}

	.how__chip--active {
		color: var(--color-primary-300);
		background: rgba(168, 85, 247, 0.15);
		border-color: rgba(168, 85, 247, 0.5);
	}

	.how__profile-radios {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
	}

	.how__radio {
		flex: 1 1 5rem;
		min-width: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		padding: 0.45rem 0.5rem;
		border-radius: var(--radius-md);
		font-size: 0.7rem;
		font-weight: var(--font-medium);
		color: var(--color-gray-500);
		background: rgba(255, 255, 255, 0.02);
		border: 1px solid rgba(168, 85, 247, 0.15);
		white-space: nowrap;
	}

	.how__radio--active {
		color: var(--color-primary-300);
		background: rgba(168, 85, 247, 0.12);
		border-color: rgba(168, 85, 247, 0.5);
	}

	.how__radio-dot {
		width: 0.7rem;
		height: 0.7rem;
		border-radius: 50%;
		border: 1.5px solid rgba(168, 85, 247, 0.4);
		flex-shrink: 0;
		position: relative;
	}

	.how__radio--active .how__radio-dot {
		border-color: var(--color-primary-400);
	}

	.how__radio--active .how__radio-dot::after {
		content: "";
		position: absolute;
		inset: 2px;
		border-radius: 50%;
		background: var(--color-primary-400);
	}

	.how__profile-cta {
		margin-top: 0.25rem;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.4rem;
		padding: 0.6rem 1rem;
		border-radius: var(--radius-md);
		background: linear-gradient(135deg, var(--color-primary-500), var(--color-secondary-500));
		color: white;
		font-size: 0.8rem;
		font-weight: var(--font-semibold);
		box-shadow: 0 6px 20px -10px rgba(168, 85, 247, 0.6);
	}

	/* ----- Connect card ----- */
	.how__connect-card {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 22rem;
		padding: 1.5rem;
		border-radius: var(--radius-xl);
	}

	.how__connect {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
	}

	.how__connect-side { text-align: center; }

	.how__connect-side span {
		display: block;
		margin-top: 0.5rem;
		font-size: 0.75rem;
		font-weight: var(--font-medium);
		color: var(--color-gray-600);
	}

	.how__connect-photo {
		width: 3.75rem;
		height: 3.75rem;
		border-radius: 50%;
		overflow: hidden;
		position: relative;
		border: 2px solid rgba(168, 85, 247, 0.4);
		box-shadow: 0 6px 20px -8px rgba(168, 85, 247, 0.4);
	}

	.how__connect-photo--student {
		border-color: rgba(236, 72, 153, 0.4);
		box-shadow: 0 6px 20px -8px rgba(236, 72, 153, 0.4);
	}

	.how__connect-photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.how__connect-link {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.how__connect-line {
		width: 1.5rem;
		height: 2px;
		background: linear-gradient(to right, var(--color-primary-300), var(--color-secondary-400));
	}

	.how__connect-icon {
		width: 2.75rem;
		height: 2.75rem;
		border-radius: var(--radius-lg);
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(236, 72, 153, 0.15);
		border: 1px solid rgba(236, 72, 153, 0.4);
		color: var(--color-secondary-500);
	}

	@media (max-width: 640px) {
		.how__step { grid-template-columns: 2.5rem 1fr; gap: 0.75rem; }
		.how__step-marker { width: 2.5rem; height: 2.5rem; }
		.how__step-content { padding: 1.5rem 1.25rem; }
		.how__profile-radios { flex-direction: column; }
		.how__radio { flex: 1 1 auto; justify-content: flex-start; }
	}
</style>
