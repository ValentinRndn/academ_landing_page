---
import logoAcadem from "../assets/images/logo_academ.png";
import { useTranslations, localizedPath, type Locale } from "../i18n";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const APP_URL = "https://app.academ.my";
const year = new Date().getFullYear();
---

<footer class="footer">
	<div class="footer__divider" aria-hidden="true"></div>

	<div class="footer__container">
		<div class="footer__main">
			<!-- Brand -->
			<div class="footer__brand">
				<div class="footer__brand-row">
					<img src={logoAcadem.src} alt="Academ" class="footer__logo" />
				</div>
				<p class="footer__tagline">{t("landing.footerDescription")}</p>
			</div>

			<!-- Links -->
			<div class="footer__links-grid">
				<div class="footer__links-column">
					<h4 class="footer__links-title">{t("landing.features")}</h4>
					<ul class="footer__links-list">
						<li><a href="#features">{t("landing.features")}</a></li>
						<li><a href="#how-it-works">{t("landing.howItWorks")}</a></li>
						<li><a href="#testimonials">{t("landing.testimonials")}</a></li>
						<li><a href="#faq">{t("landing.faq")}</a></li>
					</ul>
				</div>
				<div class="footer__links-column">
					<h4 class="footer__links-title">App</h4>
					<ul class="footer__links-list">
						<li><a href={`${APP_URL}/register`}>{t("landing.freeTrial")}</a></li>
						<li><a href={`${APP_URL}/login`}>{t("landing.login")}</a></li>
						<li><a href={APP_URL}>app.academ.my</a></li>
					</ul>
				</div>
				<div class="footer__links-column">
					<h4 class="footer__links-title">{t("landing.legal")}</h4>
					<ul class="footer__links-list">
						<li><a href={localizedPath(locale, "/mentions-legales")}>{t("landing.legal")}</a></li>
						<li><a href={localizedPath(locale, "/confidentialite")}>{t("landing.privacyPolicy")}</a></li>
						<li><a href="mailto:contact@academ.my">contact@academ.my</a></li>
					</ul>
				</div>
			</div>
		</div>

		<div class="footer__bottom">
			<p class="footer__copyright">© {year} Imators · {t("landing.imatorsMember")}</p>
			<div class="footer__socials">
				<a href="#" aria-label="Twitter" class="footer__social">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
					</svg>
				</a>
				<a href="#" aria-label="LinkedIn" class="footer__social">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
						<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
					</svg>
				</a>
				<a href="mailto:contact@academ.my" aria-label="Email" class="footer__social">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
						<polyline points="22,6 12,13 2,6"></polyline>
					</svg>
				</a>
			</div>
		</div>
	</div>
</footer>

<style>
	.footer {
		position: relative;
		padding: 4rem var(--spacing-section-x) 2rem;
	}

	/* Subtle gradient divider at the top */
	.footer__divider {
		position: absolute;
		top: 0;
		left: 50%;
		transform: translateX(-50%);
		width: min(80rem, 90%);
		height: 1px;
		background: linear-gradient(
			to right,
			transparent 0%,
			rgba(168, 85, 247, 0.4) 30%,
			rgba(236, 72, 153, 0.4) 70%,
			transparent 100%
		);
		pointer-events: none;
	}

	.footer__container {
		max-width: 72rem;
		margin: 0 auto;
	}

	/* ----- Main row : brand + links ----- */
	.footer__main {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		padding-bottom: 2.5rem;
	}

	@media (min-width: 768px) {
		.footer__main {
			grid-template-columns: 1.2fr 1fr;
			gap: 4rem;
		}
	}

	.footer__brand {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.footer__brand-row {
		display: flex;
		align-items: center;
		gap: 0.625rem;
	}

	.footer__logo {
		height: 2rem;
		width: auto;
	}

	.footer__logo-text {
		font-weight: var(--font-bold);
		font-size: 1.15rem;
		letter-spacing: -0.01em;
		color: var(--color-gray-900);
	}

	.footer__tagline {
		color: var(--color-gray-500);
		font-size: 0.85rem;
		line-height: var(--leading-relaxed);
		max-width: 24rem;
		margin: 0;
	}

	/* ----- Links ----- */
	.footer__links-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	@media (max-width: 640px) {
		.footer__links-grid { grid-template-columns: repeat(2, 1fr); }
	}

	.footer__links-column {
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
	}

	.footer__links-title {
		color: var(--color-gray-900);
		font-size: 0.78rem;
		font-weight: var(--font-bold);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		margin: 0;
	}

	.footer__links-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
	}

	.footer__links-list a {
		color: var(--color-gray-500);
		font-size: 0.85rem;
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.footer__links-list a:hover {
		color: var(--color-primary-400);
	}

	/* ----- Bottom row ----- */
	.footer__bottom {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(168, 85, 247, 0.12);
	}

	@media (min-width: 640px) {
		.footer__bottom {
			flex-direction: row;
			justify-content: space-between;
		}
	}

	.footer__copyright {
		color: var(--color-gray-500);
		font-size: 0.75rem;
		margin: 0;
	}

	/* ----- Socials ----- */
	.footer__socials {
		display: inline-flex;
		gap: 0.5rem;
	}

	.footer__social {
		width: 2rem;
		height: 2rem;
		border-radius: var(--radius-md);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--color-gray-500);
		background: rgba(168, 85, 247, 0.06);
		border: 1px solid rgba(168, 85, 247, 0.14);
		transition:
			color var(--transition-fast),
			background var(--transition-fast),
			border-color var(--transition-fast),
			transform var(--transition-fast);
	}

	.footer__social:hover {
		color: var(--color-primary-400);
		background: rgba(168, 85, 247, 0.12);
		border-color: rgba(168, 85, 247, 0.35);
		transform: translateY(-2px);
	}
</style>
