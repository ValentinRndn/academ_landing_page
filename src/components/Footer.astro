---
import logoAcadem from "../assets/images/logo_academ.png";
import { useTranslations, localizedPath, type Locale } from "../i18n";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const APP_URL = "https://app.academ.my";
const year = new Date().getFullYear();
---

<div class="footer-wrapper">
	<div class="footer-wrapper__bg">
		<div class="footer-wrapper__texture"></div>
	</div>
	<footer class="footer">
		<div class="footer__container">
			<div class="footer__main">
				<!-- Brand -->
				<div class="footer__brand">
					<div class="footer__brand-row">
						<img src={logoAcadem.src} alt="Academ" class="footer__logo" />
						<span class="footer__logo-text">Academ</span>
					</div>
					<p class="footer__tagline">{t("landing.footerDescription")}</p>
				</div>

				<!-- Links -->
				<div class="footer__links-grid">
					<div class="footer__links-column">
						<h4 class="footer__links-title">{t("landing.features")}</h4>
						<ul class="footer__links-list">
							<li><a href="#features">{t("landing.features")}</a></li>
							<li><a href="#how-it-works">{t("landing.howItWorks")}</a></li>
							<li><a href="#testimonials">{t("landing.testimonials")}</a></li>
							<li><a href="#faq">{t("landing.faq")}</a></li>
						</ul>
					</div>
					<div class="footer__links-column">
						<h4 class="footer__links-title">App</h4>
						<ul class="footer__links-list">
							<li><a href={`${APP_URL}/register`}>{t("landing.freeTrial")}</a></li>
							<li><a href={`${APP_URL}/login`}>{t("landing.login")}</a></li>
							<li><a href={APP_URL}>app.academ.my</a></li>
						</ul>
					</div>
					<div class="footer__links-column">
						<h4 class="footer__links-title">{t("landing.legal")}</h4>
						<ul class="footer__links-list">
							<li><a href={localizedPath(locale, "/mentions-legales")}>{t("landing.legal")}</a></li>
							<li><a href={localizedPath(locale, "/confidentialite")}>{t("landing.privacyPolicy")}</a></li>
							<li><a href="mailto:contact@academ.my">contact@academ.my</a></li>
						</ul>
					</div>
				</div>
			</div>

			<div class="footer__bottom">
				<p class="footer__copyright">© {year} Imators. {t("landing.imatorsMember")}</p>
				<p class="footer__badge">
					<span class="footer__badge-icon">✦</span>
					{t("landing.imatorsMember")}
				</p>
			</div>
		</div>
	</footer>
</div>

<style>
	.footer-wrapper {
		position: relative;
		padding: 4rem var(--spacing-section-x) var(--spacing-section-x);
		overflow: hidden;
		background: linear-gradient(135deg, var(--color-primary-700), var(--color-primary-900));
	}

	.footer-wrapper__bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		pointer-events: none;
	}

	.footer-wrapper__texture {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(to right, rgba(255, 255, 255, 0.06) 1px, transparent 1px),
			linear-gradient(to bottom, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
		background-size: 3rem 3rem;
	}

	.footer {
		position: relative;
		z-index: 1;
		background-color: var(--color-gray-50);
		padding: 4rem 0 2rem;
		border-radius: 2rem;
	}

	.footer__container {
		max-width: 72rem;
		margin: 0 auto;
		padding: 0 var(--spacing-section-x);
	}

	.footer__main {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		padding-bottom: 3rem;
	}

	@media (min-width: 768px) {
		.footer__main {
			grid-template-columns: 1.2fr 1fr;
			gap: 4rem;
		}
	}

	.footer__brand {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.footer__brand-row {
		display: flex;
		align-items: center;
		gap: 0.625rem;
	}

	.footer__logo {
		height: 2.25rem;
		width: auto;
	}

	.footer__logo-text {
		font-weight: var(--font-bold);
		font-size: 1.15rem;
		color: var(--color-gray-900);
	}

	.footer__tagline {
		color: var(--color-gray-600);
		font-size: var(--text-sm);
		line-height: var(--leading-relaxed);
		max-width: 24rem;
	}

	.footer__links-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	@media (max-width: 640px) {
		.footer__links-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.footer__links-column {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.footer__links-title {
		color: var(--color-gray-900);
		font-size: var(--text-sm);
		font-weight: var(--font-semibold);
		margin: 0;
	}

	.footer__links-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
	}

	.footer__links-list a {
		color: var(--color-gray-600);
		font-size: var(--text-sm);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.footer__links-list a:hover {
		color: var(--color-primary-600);
	}

	.footer__bottom {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		padding-top: 2rem;
		border-top: 1px solid var(--color-gray-200);
	}

	@media (min-width: 768px) {
		.footer__bottom {
			flex-direction: row;
			justify-content: space-between;
		}
	}

	.footer__copyright,
	.footer__badge {
		color: var(--color-gray-600);
		font-size: var(--text-xs);
		margin: 0;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.footer__badge-icon {
		color: var(--color-primary-500);
	}
</style>
